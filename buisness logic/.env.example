# Copy to .env and fill in values (never commit .env)
GEMINI_API_KEY=your_gemini_api_key_here
XAI_API_KEY=your_xai_grok_api_key_here

# Primary Postgres (Neon connection string works as-is)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional: separate candidates DB (defaults to same host as DATABASE_URL)
# CANDIDATES_DATABASE_URL=postgresql://user:password@host/candidates?sslmode=require

# Server
PORT=8000
CONFIG_PATH=config.yaml

# Set to 1 to enable Gemini/Grok for summaries and parse fallback (uses API quota)
LLM_LIVE=1
